# =============================================================
# CYRUS — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================

# ─────────────────────────────────────────
# APPLICATION
# ─────────────────────────────────────────
ENVIRONMENT=development          # development | production
SECRET_KEY=change-me-to-random-32-char-string

# ─────────────────────────────────────────
# DATABASE (PostgreSQL)
# ─────────────────────────────────────────
POSTGRES_DB=cyrus
POSTGRES_USER=cyrus
POSTGRES_PASSWORD=cyruspassword

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────
# FILE STORAGE (MinIO — self-hosted S3)
# ─────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=cyrus-files
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# For cloud mode (Supabase Storage) — leave blank for local MinIO
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ─────────────────────────────────────────
# AI — LOCAL (Ollama on GTX 1650 laptop)
# ─────────────────────────────────────────
# Point this at your GTX 1650 laptop's IP address
# Example: http://192.168.1.50:11434
# For local dev: http://localhost:11434
# For Docker: http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama models to use (must be pulled on server first)
# ollama pull mistral:7b-instruct-q4_K_M
# ollama pull llava:7b-q4_K_M
# ollama pull nomic-embed-text
OLLAMA_GRADING_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_VISION_MODEL=llava:7b-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─────────────────────────────────────────
# AI — CLOUD FALLBACK (Groq — free tier)
# Get free key at: https://console.groq.com
# ─────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────
# OCR PIPELINE
# ─────────────────────────────────────────
OCR_MODE=ensemble                # ensemble | trocr_only | cloud
OCR_CONFIDENCE_THRESHOLD=0.7     # below this → flag for teacher review
OCR_FINETUNE_THRESHOLD=200       # corrections needed before fine-tuning is available
OCR_CACHE_DIR=/root/.cache/huggingface

# ─────────────────────────────────────────
# EMAIL (Resend — free 100/day)
# Get free key at: https://resend.com
# ─────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@cyrus.app

# ─────────────────────────────────────────
# GOOGLE SHEETS EXPORT (optional)
# Create service account at: console.cloud.google.com
# ─────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=

# ─────────────────────────────────────────
# FRONTEND
# ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Cyrus

# ─────────────────────────────────────────
# SECURITY (Optional — adds HTTP Basic Auth)
# Leave blank to disable (open access by default)
# ─────────────────────────────────────────
ADMIN_PIN=
